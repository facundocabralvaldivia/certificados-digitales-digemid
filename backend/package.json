{
  "name": "cert-backend-web3",
  "version": "1.0.0",
  "description": "Backend productivo de verificacion de certificados farmaceuticos: SQL Server + Merkle Tree + anclaje en Polygon (Amoy/PoS).",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "db:seed": "tsx src/db/seed.ts",
    "deploy:contract": "tsx src/scripts/deploy-contract.ts",
    "anchor": "tsx src/scripts/anchor-now.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "ethers": "^6.13.5",
    "express": "^4.21.2",
    "mssql": "^11.0.1",
    "node-cron": "^3.0.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/mssql": "^12.3.0",
    "@types/node": "^22.10.5",
    "@types/node-cron": "^3.0.11",
    "prettier": "^3.9.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
