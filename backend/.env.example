# ============================================================================
#  CONFIGURACION DEL BACKEND — copia este archivo a .env y completa los valores
#  NUNCA subas .env al repositorio (ya esta en .gitignore).
# ============================================================================

NODE_ENV=development
PORT=8002

# ── SQL Server ───────────────────────────────────────────────────────────────
DB_SERVER=localhost
DB_PORT=1433
DB_NAME=CertVerificacion
DB_USER=sa
DB_PASSWORD=CAMBIAR_ESTA_CLAVE
DB_ENCRYPT=true
DB_TRUST_SERVER_CERTIFICATE=true

# ── Polygon (dev = Amoy) ─────────────────────────────────────────────────────
POLYGON_RPC_URL=https://rpc-amoy.polygon.technology
POLYGON_CHAIN_ID=80002
EXPLORER_TX_BASE=https://amoy.polygonscan.com/tx

# Direccion del contrato CertificateAnchor desplegado (ver contracts/README).
ANCHOR_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# ⚠ SENSIBLE: clave privada de la wallet institucional. SOLO backend. SOLO para anclar.
# Dejar vacia si solo vas a leer/verificar. En produccion usar KMS/HSM, no texto plano.
WALLET_PRIVATE_KEY=

# ── Jobs ─────────────────────────────────────────────────────────────────────
ANCHOR_CRON=0 3 * * *
RUN_CRON=false
